generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Company {
  id Int @id @default(autoincrement())

  companyName String
  logo        String?
  country     String
  state       String
  stateCode   String
  district    String
  city        String

  pincode String

  addressLine1 String
  addressLine2 String?

  mobileNumber String
  phoneNumber  String?

  gstNumber String
  panNumber String

  bankName       String
  bankHolderName String
  ifscCode       String
  branchLocation String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financialYears FinancialYear[]
}

model FinancialYear {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  companyName String

  financialYear String
  fyStartDate   DateTime
  fyEndDate     DateTime

  createdAt DateTime @default(now())

  @@unique([companyId, financialYear])
}

model Category {
  id Int @id @default(autoincrement())

  categoryName String @unique
  status       String @default("ACTIVE")

  brands          Brand[]
  models          Model[]
  modelYears      ModelYear[]
  variants        Variant[]
  websiteVariants WebsiteVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Brand {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandName String
  image     String?
  status    String  @default("ACTIVE")

  models          Model[]
  modelYears      ModelYear[]
  variants        Variant[]
  websiteVariants WebsiteVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Model {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  modelName String
  image     String?
  status    String  @default("ACTIVE")

  modelYears       ModelYear[]
  showroomVariants ShowroomVariant[]
  variants         Variant[]
  websiteVariants  WebsiteVariant[]
    colours          Colour[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ModelYear {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  modelId Int
  model   Model @relation(fields: [modelId], references: [id])

  modelYear String

  image           String?
  status          String           @default("ACTIVE")
  variants        Variant[]
  websiteVariants WebsiteVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ShowroomVariant {
  id Int @id @default(autoincrement())

  modelId Int
  model   Model @relation(fields: [modelId], references: [id])

  variantName String

  purPrice      Float
  purTaxPercent Float

  exShowroomPrice      Float
  exShowroomTaxPercent Float

  insurance           Float
  insuranceTaxPercent Float

  rtoCharge     Float
  rtoTaxType    String
  rtoTaxPercent Float

  salesPrice Float

  status String @default("ACTIVE")

  accessories ShowroomVariantAccessory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShowroomVariantAccessory {
  id Int @id @default(autoincrement())

  showroomVariantId Int

  showroomVariant ShowroomVariant @relation(fields: [showroomVariantId], references: [id], onDelete: Cascade)

  accessoryName String

  price Float

  taxPercent Float

  totalPrice Float

  createdAt DateTime @default(now())
}

model Variant {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  modelId Int
  model   Model @relation(fields: [modelId], references: [id])

  modelYearId Int
  modelYear   ModelYear @relation(fields: [modelYearId], references: [id])

  variantCode     String           @unique
  variantName     String
  websiteVariants WebsiteVariant[]
    colours          Colour[]
  image           String?
  status          String           @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebsiteVariant {
  id Int @id @default(autoincrement())

  // =========================
  // SYSTEM
  // =========================
  currentStep Int     @default(1)
  status      String  @default("DRAFT")
  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================
  // BASIC INFORMATION
  // =========================
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  brandId Int?
  brand   Brand? @relation(fields: [brandId], references: [id])

  modelId Int?
  model   Model? @relation(fields: [modelId], references: [id])

  modelYearId Int?
  modelYear   ModelYear? @relation(fields: [modelYearId], references: [id])

  variantId Int?
  variant   Variant? @relation(fields: [variantId], references: [id])

  variantCode String?
  productName String?
  productCode String?
  skuCode     String?

  launchYear DateTime?

  country       String?
  tractorStatus String?

  shortDescription String? @db.Text

  highlight1 String?
  highlight2 String?
  highlight3 String?
  highlight4 String?
  highlight5 String?

  redColor    Boolean @default(false)
  blueColor   Boolean @default(false)
  greenColor  Boolean @default(false)
  orangeColor Boolean @default(false)
  blackColor  Boolean @default(false)
  whiteColor  Boolean @default(false)
  customColor Boolean @default(false)

  customColorName String?
  customColorCode String?

  availableStates    Json?
  availableDistricts Json?
  availableDealers   Json?

  stockStatus String?

  seoTitle        String?
  seoUrl          String?
  metaDescription String? @db.Text
  keywords        String?

  // =========================
  // ENGINE DETAILS
  // =========================
  engineType String?
  fuelType   String?

  horsePower        Int?
  numberOfCylinders String?

  cubicCapacity Int?
  ratedRpm      Int?

  aspiratedType String?
  emissionNorms String?

  coolingSystem String?
  airFilterType String?

  maximumTorque Float?
  torqueRpm     Float?
  torqueBackup  Float?

  engineCondition String?

  // =========================
  // TRANSMISSION
  // =========================
  clutchType String?

  forwardGears Int?
  reverseGears Int?

  gearType         String?
  transmissionType String?

  ptoHp  Int?
  ptoRpm Int?

  ptoType     String?
  ptoPosition String?

  creeperGears  Boolean @default(false)
  shuttleShift  Boolean @default(false)
  sideShiftGear Boolean @default(false)
  powerShuttle  Boolean @default(false)
  hiLoGears     Boolean @default(false)
  multiSpeedPto Boolean @default(false)
  reversePto    Boolean @default(false)
  superReducer  Boolean @default(false)

  // =========================
  // HYDRAULIC
  // =========================
  liftingCapacity        Int?
  liftingCapacityAt610mm Int?

  hydraulicType String?

  addc            Boolean @default(false)
  positionControl Boolean @default(false)
  draftControl    Boolean @default(false)

  controlType String?

  remoteValveType      String?
  numberOfRemoteValves String?

  threePointLinkage String?
  linkageCategory   String?

  topLink          String?
  draftSensitivity String?

  externalHydraulicCylinder Boolean @default(false)
  selfLevelling             Boolean @default(false)
  quickHitch                Boolean @default(false)
  downPositionControl       Boolean @default(false)
  loadSensing               Boolean @default(false)
  flowControl               Boolean @default(false)
  returnToDepth             Boolean @default(false)
  transportLock             Boolean @default(false)

  // =========================
  // PRICE & LOCATION
  // =========================
  exShowroomPrice Float?
  onRoadPrice     Float?

  currency String?
  gst      Float?

  tcsApplicable String?
  tcsPercentage Float?

  financeAvailable String?
  emiAvailable     String?

  downPayment Float?
  offerPrice  Float?

  negotiable    String?
  exchangeOffer String?

  state    String?
  district String?
  taluka   String?
  city     String?

  pincode  String?
  landmark String?

  fullAddress    String? @db.Text
  searchLocation String?

  latitude  Float?
  longitude Float?

  // =========================
  // IMAGES
  // =========================
  frontView String?
  leftView  String?
  rightView String?
  rearView  String?

  engineView    String?
  dashboardView String?
  tyreView      String?
  hydraulicView String?
  ptoView       String?

  chassisNumber String?
  rcBook        String?

  additionalImage1 String?
  additionalImage2 String?
  additionalImage3 String?
  additionalImage4 String?
  additionalImage5 String?

  // =========================
  // VIDEOS
  // =========================

  // =========================
  // DOCUMENTS
  // =========================
  brochure             String?
  warrantyCard         String?
  insuranceCertificate String?
  invoice              String?
  others               String?

  // =========================
  // SUBMISSION
  // =========================
  agreed Boolean @default(false)
}
model Colour {
  id Int @id @default(autoincrement())

  modelId Int
  model   Model @relation(fields: [modelId], references: [id])

  variantId Int
  variant   Variant @relation(fields: [variantId], references: [id])

  colourName String
  colourCode String

  status String @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Account {
  id               Int      @id @default(autoincrement())

  accountName      String
  printName        String
  group            String
  openingBalance   Float    @default(0)
  drCr             String

  country          String?
  countryCode      String?

  state            String?
  stateCode        String?

  district         String?
  taluka           String?
  city             String?
  area             String?

  address1         String?
  address2         String?

  pincode          String?

  phone            String?
  mobile           String?

  email            String?
  contactPerson    String?

  birthday         DateTime?
  anniversary      DateTime?

  bankAccountNo    String?
  bankName         String?
  ifscCode         String?
  branch           String?

  gstNo            String?
  panCard          String?
  aadharNo         String?

  status           String   @default("ACTIVE")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
model EnquiryType {
  id            Int      @id @default(autoincrement())
  enquiryType   String
  status        String   @default("ACTIVE")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model EnquirySource {
  id              Int      @id @default(autoincrement())
  enquirySource   String
  status          String   @default("ACTIVE")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model Profession {
  id          Int      @id @default(autoincrement())
  profession  String
  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Banker {
  id         Int      @id @default(autoincrement())
  banker     String
  status     String   @default("ACTIVE")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model Finance {
  id         Int      @id @default(autoincrement())
  finance    String
  status     String   @default("ACTIVE")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model EnquiryStatus {
  id               Int      @id @default(autoincrement())
  enquiryStatus    String
  status           String   @default("ACTIVE")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
model Employee {
  id                Int      @id @default(autoincrement())

  department        String
  branch            String
  role              String

  employeeName      String

  mobileNumber      String   @unique
  alternateNumber   String?

  email             String   @unique
  password          String

  status            String   @default("ACTIVE")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}